{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20", "npm"]
        },
        "install": {
          "cmds": ["cd dashboard && npm install"]
        },
        "build": {
          "cmds": ["cd dashboard && npm run build"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd dashboard && npm run preview -- --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
